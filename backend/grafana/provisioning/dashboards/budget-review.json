{
  "title": "Budget And Review",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Budget Exceeded",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "sum by (budget_type) (rate(budget_exceeded_total[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Daily Cost",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "daily_cost_usd", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Judge Decisions",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "sum by (decision) (rate(judge_decisions_total[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Judge Quality Score",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(judge_quality_score_bucket[5m])))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Review Notifications",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "sum by (status) (rate(blog_generations_total[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ]
}
