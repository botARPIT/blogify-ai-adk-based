# Blogify AI Production Environment Variables
# Copy this to .env and update values

# Database
POSTGRES_DB=blogify
POSTGRES_USER=blogify
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://blogify:changeme_strong_password@postgres:5432/blogify

# Redis
REDIS_URL=redis://redis:6379/0

# API Keys
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Environment
ENVIRONMENT=production

# Monitoring
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=blogify-api

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_strong_password

# API URL (for frontend)
API_URL=https://api.yourdomain.com

# Optional: Session secret
SESSION_SECRET=your_session_secret_here